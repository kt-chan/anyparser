# Remote Backend Config
REMOTE_HOST=172.20.0.10
REMOTE_PORT=22
REMOTE_USER=root
REMOTE_KEY_PATH=keys/id_rsa
REMOTE_MINERU_DIR=/home/demo/docker/mineru

# VLLM Config
VLLM_ENDPOINT=http://172.20.0.10:8000/v1
VLLM_MODEL_ID=MinerU-2.5

# Overrides for MinerU SDK (default to VLLM values if not provided)
# MINERU_VL_MODEL_NAME=MinerU-2.5
# MINERU_VL_SERVER=http://172.20.0.10:8000/v1

# Local Config
TEMP_DIR=temp
LOGS_DIR=logs
ENABLE_DAILY_CLEANUP=true
